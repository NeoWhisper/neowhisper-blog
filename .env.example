# App / site runtime
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_ADSENSE_ID=
NEXT_PUBLIC_SITE_URL=https://www.neowhisper.net
CANONICAL_REDIRECT_SKIP_HOSTS=localhost,127.0.0.1,.vercel.app
RESEND_API_KEY=
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
ADMIN_EMAILS=

# Daily content scheduler defaults
RUN_HOUR=9
RUN_MINUTE=30

# Daily trend generator (OpenAI-compatible API)
# Local Ollama example:
# OPENAI_BASE_URL=http://127.0.0.1:11434/v1
# OPENAI_MODEL=qwen3:14b
# OPENAI_API_MODE=local
# OPENAI_API_KEY=sk-local
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
OPENAI_API_MODE=auto
OPENAI_API_KEY=

# Trend post metadata
TREND_POST_COVER_IMAGE=/og-image.jpg
TREND_POST_AUTHOR_NAME=NeoWhisper

# Optional editorial angle override
TOPIC_HINT=
