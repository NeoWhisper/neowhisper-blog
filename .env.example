# App / site runtime
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_ADSENSE_ID=
NEXT_PUBLIC_SITE_URL=https://www.neowhisper.net
CANONICAL_REDIRECT_SKIP_HOSTS=localhost,127.0.0.1,.vercel.app
RESEND_API_KEY=
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ADMIN_EMAILS=

# Daily content scheduler defaults
RUN_HOUR=9
RUN_MINUTE=30

# Daily trend generator (OpenAI-compatible API)
# Local Ollama example:
# OPENAI_BASE_URL=http://127.0.0.1:11434/v1
# OPENAI_MODEL=qwen3.6:latest
#
# Local LM Studio example:
# OPENAI_BASE_URL=http://127.0.0.1:1234/v1
# OPENAI_MODEL=qwen3.6-35b-a3b-ud-mlx
#
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
OPENAI_API_MODE=auto
OPENAI_API_KEY=


# Trend post metadata
TREND_POST_COVER_IMAGE=/og-image.jpg
TREND_POST_AUTHOR_NAME=NeoWhisper

# Optional editorial angle override
TOPIC_HINT=

# Image generation for trend posts
# Option 1: mflux (recommended for MLX Macs)
MFLUX_MODEL=AITRADER/FLUX1-dev-mlx-4bit
# Option 2: LM Studio (OpenAI-compatible API for vision models)
LM_STUDIO_IMAGE_URL=http://127.0.0.1:1234/v1
# Option 3: Ollama vision models (fallback)
OLLAMA_IMAGE_MODEL=
OLLAMA_BASE_URL=http://127.0.0.1:11434
