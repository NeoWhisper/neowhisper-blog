{
  "name": "neowhisper-blog",
  "version": "1.14.3",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "jest",
    "test:e2e": "playwright test",
    "content:daily": "node --import tsx --env-file-if-exists=.env.local scripts/generate-daily-ai-trend-posts.ts",
    "content:check": "node --import tsx --env-file-if-exists=.env.local scripts/generate-daily-ai-trend-posts.ts --dry-run --validate-config --lang=en",
    "content:test-flags": "node --test scripts/tests/content-flags.test.mjs",
    "content:test-safety": "node --import tsx --test scripts/tests/content-safety.test.mjs",
    "content:test-site-url": "node --import tsx --test scripts/tests/site-url-smoke.test.mjs",
    "send:subscribers": "node --import tsx --env-file-if-exists=.env.local scripts/send-subscriber-updates.ts",
    "content:typecheck": "tsc -p tsconfig.scripts.json --noEmit",
    "content:list-categories": "node --import tsx scripts/list-categories-with-counts.ts",
    "content:daily:pr": "bash scripts/local-daily-content-pr.sh",
    "content:daily:install-launchd": "bash scripts/install-launchd-daily-content.sh",
    "content:pattern:pr": "bash scripts/pattern-content-pr.sh",
    "content:sync-main": "bash scripts/sync-local-main.sh",
    "content:sync-main:install-launchd": "bash scripts/install-launchd-sync-main.sh",
    "prepare": "husky"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.2.2",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.100.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "he": "^1.2.0",
    "highlight.js": "^11.11.1",
    "isomorphic-dompurify": "^3.8.0",
    "lucide-react": "^1.7.0",
    "marked": "^18.0.0",
    "next": "^16.2.2",
    "next-mdx-remote": "^6.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "reading-time": "^1.5.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "striptags": "^3.2.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@playwright/test": "^1.59.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@tailwindcss/postcss": "^4",
    "@types/he": "^1.2.3",
    "@types/jest": "^30.0.0",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "semantic-release": "^25.0.3",
    "tailwindcss": "^4",
    "tailwindcss-animate": "^1.0.7",
    "ts-jest": "^29.4.9",
    "tsx": "^4.20.6",
    "typescript": "^5"
  },
  "overrides": {
    "tar": ">=7.5.8"
  }
}
